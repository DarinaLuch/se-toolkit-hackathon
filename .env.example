# NewsAPI key — get a free one at https://newsapi.org/register
# If left empty, the app uses built-in mock articles (good for testing)
NEWS_API_KEY=

# LLM Provider: anthropic | openai | qwen
# Use "qwen" if you have the Qwen proxy from Lab 7/8 running on port 42005
LLM_PROVIDER=qwen

# Your API key — for Qwen proxy this is the key set in the proxy config
LLM_API_KEY=my-secret-qwen-key

# Base URL for Qwen proxy running on the same VM host:
LLM_BASE_URL=http://host.docker.internal:42005/v1

# Model name — for Qwen proxy use coder-model
LLM_MODEL=coder-model

# --- Anthropic alternative ---
# LLM_PROVIDER=anthropic
# LLM_API_KEY=sk-ant-...
# LLM_BASE_URL=
# LLM_MODEL=claude-sonnet-4-20250514

# --- OpenAI alternative ---
# LLM_PROVIDER=openai
# LLM_API_KEY=sk-...
# LLM_BASE_URL=
# LLM_MODEL=gpt-4o-mini
